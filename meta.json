{
  "$schema": "https://dl.viam.dev/module.schema.json",
  "module_id": "dtcurrie:camera-360",
  "visibility": "public",
  "url": "https://github.com/DTCurrie/camera-360",
  "description": "Viam camera driver for 360 cameras.",
  "applications": null,
  "markdown_link": "README.md",
  "entrypoint": "bin/camera-360",
  "first_run": "",
  "models": [
    { "api": "rdk:component:camera", "model": "dtcurrie:camera-360:akaso-360-camera" },
    { "api": "rdk:component:camera", "model": "dtcurrie:camera-360:jvcu360-camera" },
    {
      "api": "rdk:component:audio_in",
      "model": "dtcurrie:camera-360:jvcu360-mic"
    },
    {
      "api": "rdk:service:discovery",
      "model": "dtcurrie:camera-360:discovery"
    }
  ],
  "build": {
    "build": "make module.tar.gz",
    "setup": "make setup",
    "path": "module.tar.gz",
    "arch": ["linux/amd64", "linux/arm64", "darwin/arm64", "windows/amd64"]
  }
}
