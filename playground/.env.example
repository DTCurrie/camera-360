# Live-machine connection for `pnpm dev:live` / `make playground-live`.
#
# Copy this file to `.env.live.local` (gitignored) and fill in the values for a
# real Viam machine running the camera-360 module on the target device. Leave it
# unset to dial the local viam-server instead (the default `pnpm dev` flow).
#
# Find these in the Viam app on your machine's CONNECT tab:
#   - VITE_VIAM_HOST     : the machine main part address (e.g. <name>-main.<id>.viam.cloud)
#   - VITE_VIAM_PART_ID  : the machine part ID
#   - VITE_VIAM_API_KEY_ID / VITE_VIAM_API_KEY : an API key created for the machine/location

VITE_VIAM_HOST=
VITE_VIAM_PART_ID=
VITE_VIAM_API_KEY_ID=
VITE_VIAM_API_KEY=

# Optional; defaults to https://app.viam.com:443 when unset.
# VITE_VIAM_SIGNALING_ADDRESS=https://app.viam.com:443
